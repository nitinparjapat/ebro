# Backend environment variables
# Use this format in Render/Railway/Fly or local .env tooling.

# Prefer DATABASE_URL for PostgreSQL providers like Neon/Supabase.
# Example: postgres://username:password@host:5432/database
DATABASE_URL=

# Optional fallback if DATABASE_URL is not provided.
ConnectionStrings__DefaultConnection=

JwtSettings__Secret=
JwtSettings__Issuer=BrothersStoreApi
JwtSettings__Audience=BrothersStoreClient
JwtSettings__ExpirationMinutes=120

Google__ClientId=
Google__ClientSecret=

Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://127.0.0.1:5173

Swagger__Enabled=false

PublicSite__BaseUrl=
PublicSite__LogoUrl=

Smtp__Enabled=false
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=
Smtp__Password=
Smtp__FromEmail=
Smtp__FromName=Brothers Store
Smtp__EnableSsl=true

# Comma-separated list for providers that don't support indexed arrays nicely.
# If you want multiple values, you can also use AdminNotification__Recipients__0, __1, etc.
AdminNotification__Recipients__0=

# Razorpay (Online payments)
# Preferred (ASP.NET configuration binding)
Razorpay__KeyId=
Razorpay__KeySecret=
Razorpay__MerchantName=Brothers Store

# Compatible names (also supported)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_MERCHANT_NAME=Brothers Store
